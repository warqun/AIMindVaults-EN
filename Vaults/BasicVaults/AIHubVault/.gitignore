# ═══════════════════════════════════════════
# Obsidian — plugins / cache / UI state
# ═══════════════════════════════════════════
.obsidian/plugins/*/data.json
!.obsidian/plugins/obsidian-shellcommands/data.json
.obsidian/plugins/mcp-tools/
.obsidian/workspace.json

# ═══════════════════════════════════════════
# Obsidian plugin cache / embeddings
# ═══════════════════════════════════════════
.smart-env/
.makemd/
.space/
.playwright-mcp/

# ═══════════════════════════════════════════
# Obsidian trash
# ═══════════════════════════════════════════
.trash/

# ═══════════════════════════════════════════
# Claude Code — sessions / local settings
# ═══════════════════════════════════════════
.claude/sessions/
.claude/settings.local.json
.claude/agents/
.claude/skills/

# ═══════════════════════════════════════════
# bkit — auto-generated state
# ═══════════════════════════════════════════
.bkit/

# ═══════════════════════════════════════════
# Auto-generated logs
# ═══════════════════════════════════════════
recent_files.txt

# ═══════════════════════════════════════════
# OS temp files
# ═══════════════════════════════════════════
.DS_Store
Thumbs.db
desktop.ini
